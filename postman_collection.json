{
  "info": {
    "name": "Kubernetes Go API Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "List items",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items"
          ]
        }
      }
    },
    {
      "name": "Create item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo item\",\n  \"description\": \"Created from Postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
